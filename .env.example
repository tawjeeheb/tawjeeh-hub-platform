# ============================================================================
# Tawjeeh HUB — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` or any real secret to the repository.
# ============================================================================

# --- App ---------------------------------------------------------------------
# Public base URL of the deployment (used for redirects / webhook callbacks).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Project URL and anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Grants full DB access, bypasses RLS.
# Never expose this to the client and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Name of the PRIVATE storage bucket holding paid PDF files.
SUPABASE_PRIVATE_BUCKET=product-files

# Signed URL expiry for protected downloads, in seconds (short-lived).
DOWNLOAD_URL_EXPIRY_SECONDS=120

# --- Payments (adapter placeholder) -----------------------------------------
# One of: mock | moyasar | hyperpay | paytabs
PAYMENT_PROVIDER=mock

# Secret used to verify incoming payment webhook signatures.
PAYMENT_WEBHOOK_SECRET=

# Provider API keys (server only) — fill the one you use.
MOYASAR_SECRET_KEY=
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_ENTITY_ID=
PAYTABS_SERVER_KEY=
PAYTABS_PROFILE_ID=

# --- Rate limiting (optional, placeholder) ----------------------------------
# Upstash Redis REST credentials for distributed rate limiting.
# If unset, an in-memory limiter is used (single-instance only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
